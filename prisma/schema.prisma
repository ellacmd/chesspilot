generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Game {
  id        String     @id @default(cuid())
  source    String?
  white     String
  black     String
  whiteElo  Int?
  blackElo  Int?
  event     String?
  site      String?
  playedAt  DateTime?
  result    String?
  opening   String?
  eco       String?
  pgn       String
  movesJson Json?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  positions Position[]
  chunks    Chunk[]
}

model Position {
  id         String   @id @default(cuid())
  gameId     String
  ply        Int
  fen        String
  san        String
  uci        String
  sideToMove String
  createdAt  DateTime @default(now())

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([fen])
  @@index([ply])
}

model Chunk {
  id        String   @id @default(cuid())
  gameId     String
  type       String
  startPly   Int
  endPly     Int
  summary    String?
  tags       Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  embedding Json?  
  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([type])
}